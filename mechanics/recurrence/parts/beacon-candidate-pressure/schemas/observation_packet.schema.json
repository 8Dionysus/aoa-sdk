{
  "$defs": {
    "ObservationRecord": {
      "additionalProperties": false,
      "properties": {
        "observation_ref": {
          "title": "Observation Ref",
          "type": "string"
        },
        "component_ref": {
          "title": "Component Ref",
          "type": "string"
        },
        "owner_repo": {
          "title": "Owner Repo",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "category": {
          "enum": [
            "change_pressure",
            "evidence_pressure",
            "usage_gap",
            "repeat_pattern",
            "review_signal",
            "overclaim_risk"
          ],
          "title": "Category",
          "type": "string"
        },
        "signal": {
          "title": "Signal",
          "type": "string"
        },
        "source_inputs": {
          "items": {
            "type": "string"
          },
          "title": "Source Inputs",
          "type": "array"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "attributes": {
          "additionalProperties": true,
          "title": "Attributes",
          "type": "object"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        }
      },
      "required": [
        "observation_ref",
        "component_ref",
        "owner_repo",
        "observed_at",
        "category",
        "signal"
      ],
      "title": "ObservationRecord",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "aoa_observation_packet_v1",
      "default": "aoa_observation_packet_v1",
      "title": "Schema Version",
      "type": "string"
    },
    "packet_ref": {
      "title": "Packet Ref",
      "type": "string"
    },
    "workspace_root": {
      "title": "Workspace Root",
      "type": "string"
    },
    "signal_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Signal Ref"
    },
    "observations": {
      "items": {
        "$ref": "#/$defs/ObservationRecord"
      },
      "title": "Observations",
      "type": "array"
    }
  },
  "required": [
    "packet_ref",
    "workspace_root"
  ],
  "title": "ObservationPacket",
  "type": "object"
}
