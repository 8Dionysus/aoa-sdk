{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Titan Console State",
  "type": "object",
  "required": [
    "version",
    "session_id",
    "workspace",
    "operator",
    "surface_role",
    "authority",
    "runtime_execution_state",
    "transport_state",
    "state_semantics",
    "operator_field_authenticated",
    "status",
    "titans",
    "events",
    "approvals",
    "created_at"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "session_id": {
      "type": "string"
    },
    "workspace": {
      "type": "string"
    },
    "operator": {
      "type": "string"
    },
    "surface_role": {
      "const": "titan_console_witness"
    },
    "authority": {
      "const": "witness_only"
    },
    "runtime_execution_state": {
      "const": "not_run"
    },
    "transport_state": {
      "const": "not_sent"
    },
    "state_semantics": {
      "const": "helper_projection_only"
    },
    "operator_field_authenticated": {
      "const": false
    },
    "status": {
      "enum": [
        "open",
        "closed"
      ]
    },
    "created_at": {
      "type": "string"
    },
    "closed_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "titans": {
      "type": "object"
    },
    "events": {
      "type": "array"
    },
    "approvals": {
      "type": "array"
    },
    "digest": {
      "type": "object"
    }
  }
}
