{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Titan Operator Approval",
  "type": "object",
  "required": [
    "ts",
    "titan",
    "gate",
    "reason",
    "decision_ref",
    "approved_by",
    "approved_by_authenticated",
    "authority"
  ],
  "properties": {
    "ts": {
      "type": "string"
    },
    "titan": {
      "enum": [
        "Forge",
        "Delta"
      ]
    },
    "gate": {
      "enum": [
        "mutation",
        "judgment"
      ]
    },
    "reason": {
      "type": "string"
    },
    "decision_ref": {
      "type": "string",
      "minLength": 1
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    },
    "approved_by_authenticated": {
      "const": false
    },
    "authority": {
      "const": "witness_only"
    }
  }
}
