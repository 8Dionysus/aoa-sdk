{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-sdk/mechanics/titan/parts/incarnation-identity-runtime-helper-contracts/schemas/titan_gate_event.schema.json",
  "title": "AoA Titan gate event",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "gate_ref",
    "session_id",
    "titan_name",
    "bearer_id",
    "gate_kind",
    "payload",
    "decision_ref",
    "approved_by",
    "approved_by_authenticated",
    "authority",
    "created_at"
  ],
  "properties": {
    "gate_ref": {
      "type": "string",
      "pattern": "^gate:"
    },
    "session_id": {
      "type": "string"
    },
    "titan_name": {
      "enum": [
        "Forge",
        "Delta"
      ]
    },
    "bearer_id": {
      "type": "string",
      "pattern": "^titan:"
    },
    "gate_kind": {
      "enum": [
        "mutation",
        "judgment"
      ]
    },
    "payload": {
      "type": "object"
    },
    "decision_ref": {
      "type": "string",
      "minLength": 1
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    },
    "approved_by_authenticated": {
      "const": false
    },
    "authority": {
      "const": "witness_only"
    },
    "created_at": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "titan_name": {
            "const": "Forge"
          }
        }
      },
      "then": {
        "properties": {
          "gate_kind": {
            "const": "mutation"
          },
          "payload": {
            "required": [
              "mutation_surface",
              "scope",
              "expected_files",
              "rollback_note",
              "approval_ref",
              "test_plan"
            ],
            "properties": {
              "scope": {
                "type": "array",
                "minItems": 1
              },
              "expected_files": {
                "type": "array",
                "minItems": 1
              },
              "test_plan": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "titan_name": {
            "const": "Delta"
          }
        }
      },
      "then": {
        "properties": {
          "gate_kind": {
            "const": "judgment"
          },
          "payload": {
            "required": [
              "claim",
              "criteria",
              "evidence_refs",
              "verdict_scope"
            ],
            "properties": {
              "criteria": {
                "type": "array",
                "minItems": 1
              },
              "evidence_refs": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      }
    }
  ]
}
