{
  "$defs": {
    "ConnectivityGap": {
      "additionalProperties": false,
      "properties": {
        "gap_ref": {
          "title": "Gap Ref",
          "type": "string"
        },
        "severity": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ],
          "title": "Severity",
          "type": "string"
        },
        "gap_kind": {
          "enum": [
            "unmapped_changed_path",
            "unresolved_edge",
            "missing_refresh_route",
            "missing_proof_surface",
            "orphan_generated_surface",
            "projected_without_generation",
            "weak_owner_handoff",
            "missing_target_route",
            "manifest_json_error",
            "invalid_manifest_shape",
            "unknown_manifest_kind",
            "foreign_manifest_requires_adapter",
            "owner_repo_mismatch"
          ],
          "title": "Gap Kind",
          "type": "string"
        },
        "component_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Component Ref"
        },
        "owner_repo": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Owner Repo"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "recommendation": {
          "title": "Recommendation",
          "type": "string"
        }
      },
      "required": [
        "gap_ref",
        "severity",
        "gap_kind",
        "recommendation"
      ],
      "title": "ConnectivityGap",
      "type": "object"
    },
    "ManifestDiagnostic": {
      "additionalProperties": false,
      "properties": {
        "manifest_ref": {
          "title": "Manifest Ref",
          "type": "string"
        },
        "repo": {
          "title": "Repo",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "manifest_kind": {
          "default": "unknown",
          "enum": [
            "recurrence_component",
            "hook_binding_set",
            "agon_recurrence_adapter",
            "review_surface",
            "rollout_bundle",
            "wiring_plan",
            "unknown"
          ],
          "title": "Manifest Kind",
          "type": "string"
        },
        "diagnostic_kind": {
          "enum": [
            "loaded_manifest",
            "known_foreign_manifest",
            "adapter_required",
            "manifest_json_error",
            "invalid_manifest_shape",
            "unknown_manifest_kind",
            "owner_repo_mismatch"
          ],
          "title": "Diagnostic Kind",
          "type": "string"
        },
        "severity": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ],
          "title": "Severity",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "evidence": {
          "additionalProperties": true,
          "title": "Evidence",
          "type": "object"
        }
      },
      "required": [
        "manifest_ref",
        "repo",
        "path",
        "diagnostic_kind",
        "severity",
        "message"
      ],
      "title": "ManifestDiagnostic",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "aoa_connectivity_gap_report_v1",
      "default": "aoa_connectivity_gap_report_v1",
      "title": "Schema Version",
      "type": "string"
    },
    "report_ref": {
      "title": "Report Ref",
      "type": "string"
    },
    "workspace_root": {
      "title": "Workspace Root",
      "type": "string"
    },
    "signal_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Signal Ref"
    },
    "components_checked": {
      "items": {
        "type": "string"
      },
      "title": "Components Checked",
      "type": "array"
    },
    "gaps": {
      "items": {
        "$ref": "#/$defs/ConnectivityGap"
      },
      "title": "Gaps",
      "type": "array"
    },
    "manifest_diagnostics": {
      "items": {
        "$ref": "#/$defs/ManifestDiagnostic"
      },
      "title": "Manifest Diagnostics",
      "type": "array"
    }
  },
  "required": [
    "report_ref",
    "workspace_root"
  ],
  "title": "ConnectivityGapReport",
  "type": "object"
}
