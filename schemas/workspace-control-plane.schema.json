{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-sdk/schemas/workspace-control-plane.schema.json",
  "title": "aoa-sdk workspace control-plane capsule",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_ref",
    "owner_repo",
    "surface_kind",
    "authority_ref",
    "workspace_manifest_ref",
    "validation_refs",
    "routes"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa_sdk_workspace_control_plane_v2"
    },
    "schema_ref": {
      "const": "schemas/workspace-control-plane.schema.json"
    },
    "owner_repo": {
      "const": "aoa-sdk"
    },
    "surface_kind": {
      "const": "runtime_surface"
    },
    "authority_ref": {
      "type": "string",
      "const": "docs/boundaries.md"
    },
    "workspace_manifest_ref": {
      "type": "string",
      "const": ".aoa/workspace.toml"
    },
    "validation_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "routes": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/route"
      }
    }
  },
  "$defs": {
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_id",
        "need",
        "surface_ref",
        "verification_refs"
      ],
      "properties": {
        "route_id": {
          "type": "string",
          "minLength": 1
        },
        "need": {
          "type": "string",
          "minLength": 1
        },
        "surface_ref": {
          "type": "string",
          "minLength": 1
        },
        "verification_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
