{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-sdk/schemas/workspace-control-plane.schema.json",
  "title": "aoa-sdk workspace control-plane capsule",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_ref",
    "owner_repo",
    "surface_kind",
    "authority_ref",
    "workspace_manifest_ref",
    "validation_refs",
    "artifact_identity",
    "routes"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa_sdk_workspace_control_plane_v2"
    },
    "schema_ref": {
      "const": "schemas/workspace-control-plane.schema.json"
    },
    "owner_repo": {
      "const": "aoa-sdk"
    },
    "surface_kind": {
      "const": "runtime_surface"
    },
    "authority_ref": {
      "type": "string",
      "const": "docs/boundaries.md"
    },
    "workspace_manifest_ref": {
      "type": "string",
      "const": ".aoa/workspace.toml"
    },
    "validation_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifact_identity": {
      "$ref": "#/$defs/artifactIdentity"
    },
    "routes": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/route"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "artifactIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_class",
        "surface_state",
        "owner_repo",
        "authority_ref",
        "producer",
        "consumer_expectation",
        "privacy_boundary",
        "content_identity",
        "abi_epoch",
        "contract_version",
        "trust_layer",
        "verification",
        "action"
      ],
      "properties": {
        "artifact_class": {
          "const": "control_plane_capsule"
        },
        "surface_state": {
          "const": "public_generated_control_plane_surface"
        },
        "owner_repo": {
          "const": "aoa-sdk"
        },
        "authority_ref": {
          "const": "mechanics/runtime-seam/parts/control-plane-capsule/CONTRACT.md"
        },
        "producer": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "consumer_expectation": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "privacy_boundary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "content_identity": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "abi_epoch": {
          "const": "aoa_sdk_workspace_control_plane_v2"
        },
        "contract_version": {
          "const": "schemas/workspace-control-plane.schema.json@aoa_sdk_workspace_control_plane_v2#artifact_identity"
        },
        "trust_layer": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "abi_contract_signature"
            ]
          }
        },
        "verification": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "action": {
          "const": "ADD_CONSUMER_EXPECTATION"
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_id",
        "need",
        "surface_ref",
        "verification_refs"
      ],
      "properties": {
        "route_id": {
          "type": "string",
          "minLength": 1
        },
        "need": {
          "type": "string",
          "minLength": 1
        },
        "surface_ref": {
          "type": "string",
          "minLength": 1
        },
        "verification_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
