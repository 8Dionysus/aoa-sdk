{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/schemas/titan_agent_finding.schema.json",
  "title": "Titan agent finding",
  "type": "object",
  "required": [
    "finding_id",
    "report_id",
    "titan_name",
    "severity",
    "claim",
    "evidence_refs",
    "recommended_action",
    "status"
  ],
  "properties": {
    "finding_id": {
      "type": "string",
      "minLength": 1
    },
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "titan_name": {
      "enum": [
        "Atlas",
        "Sentinel",
        "Mneme",
        "Forge",
        "Delta"
      ]
    },
    "severity": {
      "enum": [
        "P0",
        "P1",
        "P2",
        "P3",
        "note"
      ]
    },
    "claim": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommended_action": {
      "type": "string"
    },
    "status": {
      "enum": [
        "reported",
        "confirmed",
        "fixed",
        "validated",
        "merged",
        "stale",
        "duplicate",
        "rejected",
        "memory_candidate"
      ]
    }
  },
  "additionalProperties": false
}
