{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "count": {
      "const": 7
    },
    "digest": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "helpers": {
      "items": {
        "$ref": "agon-epistemic-sdk-helper.schema.json"
      },
      "maxItems": 7,
      "minItems": 7,
      "type": "array"
    },
    "registry_id": {
      "const": "agon.epistemic_sdk_helpers.registry.v1"
    },
    "runtime_posture": {
      "const": "candidate_only"
    },
    "wave": {
      "const": "XV"
    }
  },
  "required": [
    "registry_id",
    "wave",
    "runtime_posture",
    "count",
    "helpers",
    "digest"
  ],
  "title": "Agon Epistemic SDK Helper Registry",
  "type": "object"
}
